# API Configuration
API_URL=https://api.example.com

# Commerce Provider (local, shopify, bigcommerce, etc.)
COMMERCE_PROVIDER=local

# Add other environment variables as needed

# SEO — search-console verification tokens (optional, leave blank if unused)
NEXT_PUBLIC_SEO_GOOGLE_VERIFICATION=
NEXT_PUBLIC_SEO_YANDEX_VERIFICATION=
NEXT_PUBLIC_SEO_MAILRU_VERIFICATION=
NEXT_PUBLIC_SEO_BING_VERIFICATION=
NEXT_PUBLIC_SEO_FB_VERIFICATION=

# IndexNow key (Bing/Yandex/Naver). 32-char hex.
# Served at /indexnow-key.txt (matches keyLocation in lib/seo/indexnow.ts).
INDEXNOW_KEY=

# Shared secret for POST /api/seo/indexnow webhook (used by CMS hooks).
INDEXNOW_WEBHOOK_SECRET=