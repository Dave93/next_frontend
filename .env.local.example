# API Configuration
API_URL=https://api.example.com

# Commerce Provider (local, shopify, bigcommerce, etc.)
COMMERCE_PROVIDER=local

# Add other environment variables as needed

# SEO — search-console verification tokens (optional, leave blank if unused)
NEXT_PUBLIC_SEO_GOOGLE_VERIFICATION=
NEXT_PUBLIC_SEO_YANDEX_VERIFICATION=
NEXT_PUBLIC_SEO_MAILRU_VERIFICATION=
NEXT_PUBLIC_SEO_BING_VERIFICATION=
NEXT_PUBLIC_SEO_FB_VERIFICATION=

# IndexNow key (Bing/Yandex/Naver). 32-char hex.
# Served at /indexnow-key.txt (matches keyLocation in lib/seo/indexnow.ts).
INDEXNOW_KEY=

# Shared secret for POST /api/seo/indexnow webhook (used by CMS hooks).
INDEXNOW_WEBHOOK_SECRET=

# Public store config (replaces the legacy /api/configs/public endpoint).
# All values are inlined at build time by Next.js. yandexGeoKey accepts a
# comma-separated list of keys; one is picked at random per request.
NEXT_PUBLIC_CHOPAR_YANDEX_GEO_KEY=
NEXT_PUBLIC_CHOPAR_WORK_TIME_RU=
NEXT_PUBLIC_CHOPAR_WORK_TIME_UZ=
NEXT_PUBLIC_CHOPAR_WORK_TIME_EN=
NEXT_PUBLIC_CHOPAR_WORK_TIME_START=
NEXT_PUBLIC_CHOPAR_WORK_TIME_END=
NEXT_PUBLIC_CHOPAR_DISCOUNT_VALUE=
NEXT_PUBLIC_CHOPAR_DISCOUNT_END_DATE=
NEXT_PUBLIC_CHOPAR_DISCOUNT_DISABLE_DAY=
NEXT_PUBLIC_CHOPAR_DISCOUNT_CATALOG_SECTIONS=
NEXT_PUBLIC_CHOPAR_ORDER_MIN_PRICE=44000